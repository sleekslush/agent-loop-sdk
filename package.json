{
  "name": "agent-loop-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Agent loop orchestrator SDK built on top of existing agent harnesses",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "typecheck:pi": "tsc -p .pi/tsconfig.json"
  },
  "devDependencies": {
    "@agent-loop/core": "workspace:^",
    "@agent-loop/harness-pi": "workspace:^",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/node": "^20.0.0",
    "typebox": "1.1.38",
    "typescript": "^5.5.0"
  }
}
